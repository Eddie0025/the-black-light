{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "theblacklight.blog"
        }
      ],
      "destination": "https://www.theblacklight.blog/$1",
      "permanent": true
    }
  ],
  "routes": [
    { "src": "/sitemap.xml", "dest": "/api/sitemap" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/article/(.*)", "dest": "/api/article?slug=$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/" }
  ]
}
